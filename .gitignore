# Local asset / working directories (not source, too large for git)
# Anchored to repo root so they don't accidentally match app dirs
# like apps/videos/ on case-insensitive filesystems.
/Videos/
/condo pictures/
/website photos/
/email campaigns/

# Nested standalone repo (condo search SPA has its own git)
/gsob-condo-search/

# Runtime / one-off files
/gunicorn.ctl
/update_server.py
/listings for *.csv
