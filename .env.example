# Django
SECRET_KEY=generate-a-secure-key-here
DEBUG=False
ALLOWED_HOSTS=crm.yourdomain.com,courses.yourdomain.com

# Database
DATABASE_URL=postgres://crm_user:STRONG_PASSWORD_HERE@db:5432/crm_db

# Redis
REDIS_URL=redis://redis:6379/0

# Google OAuth (for Gmail integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (for system notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-notification-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Course Portal
PORTAL_SUBDOMAIN=courses
PORTAL_URL=https://courses.bigbeachal.com
